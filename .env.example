# Flask
FLASK_SECRET_KEY=change-me-to-random-string
FLASK_DEBUG=true

# Alliance password (Slice 2 auth)
ALLIANCE_PASSWORD=change-me

# Discord Bot Token (Slice 2)
DISCORD_TOKEN=your-discord-bot-token
DISCORD_GUILD_ID=your-guild-id
DISCORD_ALERTS_CHANNEL_ID=your-alerts-channel-id
DISCORD_DEFENSE_FORUM_ID=your-defense-forum-id
DISCORD_DEF_ROLE_ID=your-def-role-id

# Discord OAuth2 (for web login)
DISCORD_CLIENT_ID=your-discord-app-client-id
DISCORD_CLIENT_SECRET=your-discord-app-client-secret
DISCORD_REDIRECT_URI=http://localhost:5000/auth/callback

# Travian Server
TRAVIAN_SERVER_URL=https://ts31.x3.europe.travian.com

# Database (leave empty for SQLite)
DATABASE_URL=

# --- Docker (używane przez docker-compose.yml) ---
POSTGRES_DB=witek
POSTGRES_USER=witek
POSTGRES_PASSWORD=change-me-to-strong-password
WITEK_PORT=5000
