# W.I.T.E.K — RoF x3 International Environment
# Kopiuj do .env.rof i uzupełnij wartości

# Profil serwera (musi być rof-x3)
SERVER_PROFILE=rof-x3

# Travian server URL (nadpisuje config.yaml jeśli ustawione)
# TRAVIAN_SERVER_URL=https://rof.x3.international.travian.com

# Discord Bot (ODDZIELNY token od ts31!)
DISCORD_TOKEN=your-rof-bot-token-here
DISCORD_GUILD_ID=your-rof-guild-id
DISCORD_ALERTS_CHANNEL_ID=
DISCORD_DEFENSE_FORUM_ID=
DISCORD_DEF_ROLE_ID=

# Flask
FLASK_SECRET_KEY=change-me-rof-secret

# PostgreSQL
POSTGRES_DB=witek_rof
POSTGRES_USER=witek
POSTGRES_PASSWORD=change-me-strong-password

# Port (domyślnie 5001 żeby nie kolidować z ts31 na 5000)
WITEK_PORT=5001

# Discord OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:5001/auth/callback

# Rozszerzenie Chrome
EXT_API_TOKEN=

# Hasło sojuszu (do logowania na dashboardzie)
ALLIANCE_PASSWORD=
