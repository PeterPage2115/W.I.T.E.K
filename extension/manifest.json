{
  "manifest_version": 3,
  "name": "W.I.T.E.K — Travian Assistant",
  "version": "0.2.1",
  "description": "Wysyła dane z Travian Legends do bota W.I.T.E.K (raporty, wojska, nadchodzące ataki)",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "*://*.travian.com/*",
    "*://*.travian.de/*",
    "*://*.travian.co.uk/*",
    "*://*.travian.us/*",
    "*://*.travian.net/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.travian.com/*",
        "*://*.travian.de/*",
        "*://*.travian.co.uk/*",
        "*://*.travian.us/*",
        "*://*.travian.net/*"
      ],
      "js": ["content/detector.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "W.I.T.E.K — Travian Assistant"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
